# NebulaAI Frontend Environment Variables
# Copy this file to .env and replace the values appropriately.

# The base URL of the FastAPI backend.
# In production (e.g., Vercel + Render), use your deployed Render URL without a trailing slash.
# For local development, this defaults to http://localhost:8000
VITE_API_BASE_URL=https://your-backend-app-name.onrender.com
